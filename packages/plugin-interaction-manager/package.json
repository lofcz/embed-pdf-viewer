{
  "name": "@lofcz/embedpdf-plugin-interaction-manager",
  "version": "2.14.6",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "scripts": {
    "build:base": "vite build --mode base",
    "build:react": "vite build --mode react",
    "build:preact": "vite build --mode preact",
    "build:vue": "vite build --mode vue",
    "build:svelte": "vite build --mode svelte",
    "build": "pnpm run clean && concurrently -c auto -n base,react \"vite build --mode base\" \"vite build --mode react\"",
    "clean": "rimraf dist",
    "lint": "eslint src --color",
    "lint:fix": "eslint src --color --fix"
  },
  "dependencies": {
    "@embedpdf/models": "workspace:@lofcz/embedpdf-models@*"
  },
  "devDependencies": {
    "@embedpdf/core": "workspace:@lofcz/embedpdf-core@*",
    "@embedpdf/build": "workspace:@lofcz/embedpdf-build@*",
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@embedpdf/core": "workspace:@lofcz/embedpdf-core@*",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lofcz/embed-pdf-viewer",
    "directory": "packages/plugin-interaction-manager"
  },
  "homepage": "https://www.embedpdf.com/docs",
  "bugs": {
    "url": "https://github.com/embedpdf/embed-pdf-viewer/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
