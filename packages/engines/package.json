{
  "name": "@lofcz/embedpdf-engines",
  "version": "2.14.5",
  "description": "Pluggable runtime layer that abstracts over multiple PDF engines (PDF-ium, Web Workers, mocks, etc.) to provide a unified API for rendering, search, annotation, and other document-level operations in EmbedPDF.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./pdfium": {
      "types": "./dist/lib/pdfium/index.d.ts",
      "import": "./dist/lib/pdfium/index.js",
      "require": "./dist/lib/pdfium/index.cjs"
    },
    "./worker": {
      "types": "./dist/lib/webworker/engine.d.ts",
      "import": "./dist/lib/webworker/engine.js",
      "require": "./dist/lib/webworker/engine.cjs"
    },
    "./converters": {
      "types": "./dist/lib/converters/index.d.ts",
      "import": "./dist/lib/converters/index.js",
      "require": "./dist/lib/converters/index.cjs"
    },
    "./pdfium-direct-engine": {
      "types": "./dist/lib/pdfium/web/direct-engine.d.ts",
      "import": "./dist/lib/pdfium/web/direct-engine.js",
      "require": "./dist/lib/pdfium/web/direct-engine.cjs"
    },
    "./pdfium-worker-engine": {
      "types": "./dist/lib/pdfium/web/worker-engine.d.ts",
      "import": "./dist/lib/pdfium/web/worker-engine.js",
      "require": "./dist/lib/pdfium/web/worker-engine.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "keywords": [
    "pdf",
    "pdf-engine",
    "embedpdf"
  ],
  "scripts": {
    "build:base": "vite build --mode base",
    "build:react": "vite build --mode react",
    "build:preact": "vite build --mode preact",
    "build:vue": "vite build --mode vue",
    "build:svelte": "vite build --mode svelte",
    "build": "pnpm run clean && concurrently -c auto -n base,react \"vite build --mode base\" \"vite build --mode react\"",
    "clean": "rimraf dist",
    "lint": "eslint src --color",
    "lint:fix": "eslint src --color --fix"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lofcz/embed-pdf-viewer",
    "directory": "packages/engines"
  },
  "homepage": "https://www.embedpdf.com/docs/engines/introduction",
  "bugs": {
    "url": "https://github.com/embedpdf/embed-pdf-viewer/issues"
  },
  "author": "Bob Singor, Ji Chang",
  "license": "MIT",
  "devDependencies": {
    "@embedpdf/build": "workspace:@lofcz/embedpdf-build@*",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@embedpdf/fonts-arabic": "workspace:@lofcz/embedpdf-fonts-arabic@*",
    "@embedpdf/fonts-hebrew": "workspace:@lofcz/embedpdf-fonts-hebrew@*",
    "@embedpdf/fonts-jp": "workspace:@lofcz/embedpdf-fonts-jp@*",
    "@embedpdf/fonts-kr": "workspace:@lofcz/embedpdf-fonts-kr@*",
    "@embedpdf/fonts-latin": "workspace:@lofcz/embedpdf-fonts-latin@*",
    "@embedpdf/fonts-sc": "workspace:@lofcz/embedpdf-fonts-sc@*",
    "@embedpdf/fonts-tc": "workspace:@lofcz/embedpdf-fonts-tc@*",
    "@embedpdf/models": "workspace:@lofcz/embedpdf-models@*",
    "@embedpdf/pdfium": "workspace:@lofcz/embedpdf-pdfium@*"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
