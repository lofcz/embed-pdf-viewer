{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "paths": {
      "@embedpdf-x/ui-core": ["../../packages/ui-core/src/index.ts"],
      "@embedpdf-x/plugin-commands": ["../../packages/plugin-commands/src/index.ts"],
      "@embedpdf-x/plugin-shell": ["../../packages/plugin-shell/src/index.ts"],
      "@embedpdf-x/react": ["../../packages/react/src/index.ts"]
    }
  },
  "include": ["src"]
}
