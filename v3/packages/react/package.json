{
  "name": "@embedpdf-x/react",
  "version": "0.0.0",
  "private": true,
  "description": "React adapter for EmbedPDF v3: one generic reactive binding + structural components (Viewer, Stage, PageView) + headless layers & hooks. The whole framework surface.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@embedpdf-x/geometry": "workspace:*",
    "@embedpdf-x/kernel": "workspace:*",
    "@embedpdf-x/plugin-stage": "workspace:*",
    "@embedpdf-x/plugin-render": "workspace:*",
    "@embedpdf-x/plugin-page-edit": "workspace:*",
    "@embedpdf-x/plugin-metadata": "workspace:*",
    "@embedpdf-x/stage-core": "workspace:*",
    "@embedpdf-x/plugin-interaction": "workspace:*",
    "@embedpdf-x/plugin-selection": "workspace:*",
    "@embedpdf-x/plugin-view-manager": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "license": "MIT"
}
