{
  "name": "@lofcz/embedpdf-example-vue-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "exports": {
    "./headless/*": "./dist/examples/headless/*.js",
    "./viewer/*": "./dist/examples/viewer/*.js"
  },
  "typesVersions": {
    "*": {
      "headless/*": [
        "./dist/examples/headless/*.d.ts"
      ],
      "viewer/*": [
        "./dist/examples/viewer/*.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:app && pnpm build:examples",
    "build:app": "vite build",
    "build:examples": "vite --config vite.lib.config.ts build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,vue --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@embedpdf/core": "workspace:@lofcz/embedpdf-core@*",
    "@embedpdf/engines": "workspace:@lofcz/embedpdf-engines@*",
    "@embedpdf/models": "workspace:@lofcz/embedpdf-models@*",
    "@embedpdf/pdfium": "workspace:@lofcz/embedpdf-pdfium@*",
    "@embedpdf/plugin-annotation": "workspace:@lofcz/embedpdf-plugin-annotation@*",
    "@embedpdf/plugin-capture": "workspace:@lofcz/embedpdf-plugin-capture@*",
    "@embedpdf/plugin-commands": "workspace:@lofcz/embedpdf-plugin-commands@*",
    "@embedpdf/plugin-document-manager": "workspace:@lofcz/embedpdf-plugin-document-manager@*",
    "@embedpdf/plugin-export": "workspace:@lofcz/embedpdf-plugin-export@*",
    "@embedpdf/plugin-form": "workspace:@lofcz/embedpdf-plugin-form@*",
    "@embedpdf/plugin-fullscreen": "workspace:@lofcz/embedpdf-plugin-fullscreen@*",
    "@embedpdf/plugin-history": "workspace:@lofcz/embedpdf-plugin-history@*",
    "@embedpdf/plugin-i18n": "workspace:@lofcz/embedpdf-plugin-i18n@*",
    "@embedpdf/ai": "workspace:@lofcz/embedpdf-ai@*",
    "@embedpdf/plugin-ai-manager": "workspace:@lofcz/embedpdf-plugin-ai-manager@*",
    "@embedpdf/plugin-interaction-manager": "workspace:@lofcz/embedpdf-plugin-interaction-manager@*",
    "@embedpdf/plugin-layout-analysis": "workspace:@lofcz/embedpdf-plugin-layout-analysis@*",
    "@embedpdf/plugin-pan": "workspace:@lofcz/embedpdf-plugin-pan@*",
    "@embedpdf/plugin-print": "workspace:@lofcz/embedpdf-plugin-print@*",
    "@embedpdf/plugin-redaction": "workspace:@lofcz/embedpdf-plugin-redaction@*",
    "@embedpdf/plugin-render": "workspace:@lofcz/embedpdf-plugin-render@*",
    "@embedpdf/plugin-rotate": "workspace:@lofcz/embedpdf-plugin-rotate@*",
    "@embedpdf/plugin-scroll": "workspace:@lofcz/embedpdf-plugin-scroll@*",
    "@embedpdf/plugin-search": "workspace:@lofcz/embedpdf-plugin-search@*",
    "@embedpdf/plugin-selection": "workspace:@lofcz/embedpdf-plugin-selection@*",
    "@embedpdf/plugin-signature": "workspace:@lofcz/embedpdf-plugin-signature@*",
    "@embedpdf/plugin-spread": "workspace:@lofcz/embedpdf-plugin-spread@*",
    "@embedpdf/plugin-stamp": "workspace:@lofcz/embedpdf-plugin-stamp@*",
    "@embedpdf/plugin-thumbnail": "workspace:@lofcz/embedpdf-plugin-thumbnail@*",
    "@embedpdf/plugin-tiling": "workspace:@lofcz/embedpdf-plugin-tiling@*",
    "@embedpdf/plugin-ui": "workspace:@lofcz/embedpdf-plugin-ui@*",
    "@embedpdf/plugin-view-manager": "workspace:@lofcz/embedpdf-plugin-view-manager@*",
    "@embedpdf/plugin-viewport": "workspace:@lofcz/embedpdf-plugin-viewport@*",
    "@embedpdf/plugin-zoom": "workspace:@lofcz/embedpdf-plugin-zoom@*",
    "@embedpdf/vue-pdf-viewer": "workspace:@lofcz/embedpdf-vue-pdf-viewer@*",
    "@embedpdf/snippet": "workspace:@lofcz/embedpdf-snippet@*",
    "@embedpdf/utils": "workspace:@lofcz/embedpdf-utils@*",
    "lucide-vue-next": "^0.562.0",
    "tailwind-merge": "^3.4.0",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@typescript-eslint/eslint-plugin": "^8.18.5",
    "@typescript-eslint/parser": "^8.18.5",
    "@vitejs/plugin-vue": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "glob": "^13.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.0.1"
  }
}
