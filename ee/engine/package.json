{
  "name": "@cloudpdf/engine",
  "version": "0.0.0",
  "private": false,
  "description": "CloudPDF engine: the cloud client that speaks the Engine v3 interface over HTTPS to a @cloudpdf/server deployment (or CloudPDF SaaS). Same AbortablePromise-based, EngineError-coded contract as the local engine.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "pnpm run clean && vite build",
    "clean": "rimraf dist",
    "lint": "eslint src --color",
    "lint:fix": "eslint src --color --fix",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/embedpdf/embed-pdf-viewer",
    "directory": "ee/engine"
  },
  "homepage": "https://www.cloudpdf.com",
  "bugs": {
    "url": "https://github.com/embedpdf/embed-pdf-viewer/issues"
  },
  "keywords": [
    "pdf",
    "cloudpdf",
    "engine",
    "cloud"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@embedpdf/engine-core": "workspace:*",
    "@embedpdf/engine-services": "workspace:^"
  },
  "devDependencies": {
    "@cloudpdf/server": "workspace:*",
    "@embedpdf/build": "workspace:*",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
