{
  "name": "@cloudpdf/admin-api",
  "version": "0.0.0",
  "private": false,
  "description": "Shared CloudPDF admin HTTP contracts and zod schemas, used by both @cloudpdf/server and the @cloudpdf/admin SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "eslint src --color",
    "lint:fix": "eslint src --color --fix"
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/embedpdf/embed-pdf-viewer",
    "directory": "ee/admin-api"
  },
  "homepage": "https://www.cloudpdf.com",
  "bugs": {
    "url": "https://github.com/embedpdf/embed-pdf-viewer/issues"
  },
  "keywords": [
    "pdf",
    "cloudpdf",
    "admin-api",
    "contracts"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "latest",
    "rimraf": "^5.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
