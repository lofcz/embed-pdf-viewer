# Published packages live under @lofcz; dep keys in source stay @embedpdf/*
# and are remapped by consumers via npm/bun overrides (plate-style fork).
@lofcz:registry=https://registry.npmjs.org/
@embedpdf:registry=https://registry.npmjs.org/

# Auth token from env (CI: secrets.NPM_TOKEN → NODE_AUTH_TOKEN / NPM_TOKEN).
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
